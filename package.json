{
  "name": "scoutcore-quant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Motor quantitativo de predição para futebol — engine A (Poisson) + engine B (XGB/LGBM) + curinga calibrado",
  "license": "UNLICENSED",
  "author": "RGMV-Automacao",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File stop.ps1",
    "dev:api": "node --watch apps/api/src/index.mjs",
    "start:api": "node apps/api/src/index.mjs",
    "setup:wipe-state": "node scripts/setup-wipe-state.mjs",
    "setup:migrate": "node scripts/setup-migrate.mjs",
    "setup:replay": "node apps/jobs/src/replay-bootstrap.mjs",
    "single-db:snapshot": "node scripts/snapshot-row-counts.mjs",
    "single-db:validate": "node scripts/validate-pre-migration.mjs",
    "single-db:copy": "node scripts/copy-scout-to-extraction.mjs",
    "extraction:migrate": "node scripts/extraction-migrate.mjs",
    "extraction:audit:schema": "node scripts/audit-extraction-schema.mjs",
    "extraction:audit:config": "node scripts/audit-extraction-config.mjs",
    "extraction:audit:bookline-live": "node scripts/audit-bookline-live-vs-legacy.mjs",
    "extraction:audit:coverage": "node scripts/audit-extraction-coverage.mjs",
    "extraction:bookline:odds": "node apps/jobs/src/extract-bookline-odds.mjs",
    "extraction:bookline:scale-out": "node scripts/extraction-scale-out-bookline.mjs",
    "extraction:bookline:backfill-live": "node scripts/backfill-bookline-live-metadata.mjs",
    "extraction:bookline:migrate-legacy-odds": "node scripts/migrate-legacy-bookline-odds.mjs",
    "extraction:statsline:schedule": "node apps/jobs/src/extract-statsline-schedule.mjs",
    "extraction:statsline:schedule:all": "node apps/jobs/src/extract-statsline-schedule.mjs --all",
    "extraction:statsline:matchstats": "node apps/jobs/src/extract-statsline-matchstats.mjs",
    "extraction:statsline:backfill-legacy-columns": "node scripts/backfill-legacy-matchstats-columns.mjs",
    "extraction:scheduler": "node apps/jobs/src/extraction-local-scheduler.mjs",
    "profiles:rebuild": "node scripts/rebuild-all-leagues.mjs",
    "job:settlement": "node apps/jobs/src/settle-results.mjs",
    "job:snapshot-closing": "node apps/jobs/src/snapshot-closing.mjs",
    "mesa:csv": "node scripts/mesa-audit-csv.mjs",
    "run:audit": "node scripts/run-audit-csv.mjs",
    "test": "node --test packages/*/test/*.test.mjs apps/*/test/*.test.mjs",
    "lint": "eslint . --ext .mjs,.cjs,.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^9.13.0"
  }
}
