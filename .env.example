# ─── SCOUTCORE_QUANT — Environment ────────────────────────────────
# Copie para .env e ajuste os paths para sua máquina.

# ─── Paths SQLite ──────────────────────────────────────────────────
# Banco unico do runtime (read+write) apos cutover 2026-05-17 (motor + extracao + backtest).
# Default: data/scout_extraction.db dentro do repo.
SCOUT_DB=C:\Users\Rogerio\Desktop\RGMV_PROJETOS\SCOUTCORE_QUANT\data\scout_extraction.db

# ─── API HTTP ──────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=4040
API_LOG_LEVEL=info

# ─── ML Sidecar Python ─────────────────────────────────────────────
ML_SIDECAR_PATH=apps/ml-sidecar/src/main.py
ML_SIDECAR_POOL_SIZE=5
ML_SIDECAR_TIMEOUT_MS=8000
# URL do sidecar uvicorn (engine-b). Sem isso, engine-b é tratado como indisponível.
ENGINE_B_URL=http://127.0.0.1:4055

# ─── Settlement & calibração ───────────────────────────────────────
BRIER_BOOTSTRAP_MIN_SAMPLES=30
EWMA_ALPHA=0.05
REVERSAL_THRESHOLD=5

# ─── Freshness Guard ───────────────────────────────────────────────
FRESHNESS_OPTA_SOFT_MS=86400000      # 24h
FRESHNESS_OPTA_HARD_MS=604800000     # 7d
FRESHNESS_ODDS_SOFT_MS=1800000       # 30min
FRESHNESS_ODDS_HARD_MS=21600000      # 6h

# ─── Sync-check ────────────────────────────────────────────────────
SYNC_DRIFT_THRESHOLD=5
SYNC_CHECK_CRON=0 3 * * *            # 03:00 diário

# ─── SCOUT (LLM auditoria opt-in, v1.5) ────────────────────────────
SCOUT_ENABLED=false
# Cérebro analítico único — obrigatório quando SCOUT estiver ativo
OPENAI_API_KEY=
# Enriquecimento web opcional (Sonar) — sem ela, SCOUT roda em modo degradado
PERPLEXITY_API_KEY=
# Reservado p/ experimentos
GEMINI_API_KEY=
# Statsline (codename OpSec do provedor de dados esportivos)
STATSLINE_TOKEN=
STATSLINE_STANDINGS_TOKEN=
STATSLINE_API_BASE=
STATSLINE_REFERER=
STATSLINE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
# URLs de schedule por liga/temporada. Preencher localmente, sem versionar valores reais.
STATSLINE_URL_BRASILEIRAO_2026=
# Tuning de timeout (ms)
SCOUT_TIMEOUT_MS=20000
SCOUT_WEB_TIMEOUT_MS=15000

# ─── Bookline submit real (opcional; mantenha vazio no exemplo) ─────
# Quando false/vazio, /yankee/submit grava auditoria local e retorna ready_for_real_submit.
SCOUTCORE_BOOKLINE_REAL_SUBMIT=false
BOOKLINE_SESSIONID=
BOOKLINE_COOKIE=

# ─── Extração local recorrente ────────────────────────────────────
SCOUT_EXTRACTION_SCHEDULE_INTERVAL_MIN=60
SCOUT_EXTRACTION_STATS_LIMIT_PER_TICK=50
SCOUT_EXTRACTION_REBUILD_PROFILES_ENABLED=true
STATSLINE_MATCHSTATS_CONCURRENCY=8
